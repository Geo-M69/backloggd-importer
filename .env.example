# Steam Web API
# Obtain from: https://steamcommunity.com/dev/apikey
STEAM_API_KEY=your_steam_api_key_here
STEAM_USER_ID=your_steam_64bit_id_here

# IGDB (Twitch) API
# Obtain from: https://dev.twitch.tv/console/apps
IGDB_CLIENT_ID=your_twitch_client_id_here
IGDB_CLIENT_SECRET=your_twitch_client_secret_here
